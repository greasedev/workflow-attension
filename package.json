{
  "name": "workflows",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "build": "npx tsx node_modules/@greaseclaw/workflow-sdk/bin/workflow-build.mjs src/workflows dist",
    "build:pages": "npx tsx node_modules/@greaseclaw/workflow-sdk/bin//page-build.mjs src/pages dist/pages",
    "dev": "npx tsx node_modules/@greaseclaw/workflow-sdk/bin/workflow-dev.mjs",
    "dev:pages": "npx tsx node_modules/@greaseclaw/workflow-sdk/bin//page-dev.mjs src/pages 3000",
    "fetch:twitter-lists": "tsx src/scripts/fetch-twitter-lists.ts",
    "classify:twitter-lists": "tsx src/scripts/classify-twitter-lists.ts",
    "fetch:twitter-list-members": "tsx src/scripts/fetch-twitter-list-members.ts",
    "generate:twitter-kols": "tsx src/scripts/generate-twitter-kols.ts",
    "tag:twitter-kols": "tsx src/scripts/tag-twitter-kols.ts",
    "export:twitter-json": "tsx src/scripts/export-twitter-json.ts",
    "test:workflow:portfolio": "npx tsx node_modules/@greaseclaw/workflow-sdk/bin/workflow-dev.mjs src/workflows/generate_portfolio_workflow.ts '{\"task\":\"Generate portfolio\",\"params\":{\"interest\":\"AI Agent\"}}'",
    "test:workflow:lists": "npx tsx node_modules/@greaseclaw/workflow-sdk/bin/workflow-dev.mjs src/workflows/create_x_lists_workflow.ts '{\"task\":\"Create lists\",\"params\":{\"interest\":\"AI Agent\",\"portfolio\":{\"core\":[{\"name\":\"OpenAI\",\"handle\":\"@OpenAI\"}],\"diversity\":[{\"name\":\"Yann LeCun\",\"handle\":\"@ylecun\"}],\"radar\":[{\"name\":\"Hugging Face\",\"handle\":\"@huggingface\"}]}}}'",
    "test:workflow:tweets": "npx tsx node_modules/@greaseclaw/workflow-sdk/bin/workflow-dev.mjs src/workflows/sync_list_tweets_workflow.ts '{\"task\":\"Sync list tweets\",\"params\":{\"interest\":\"AI Agent\",\"limit\":30}}'",
    "zip": "npm run build && npm run build:pages && && rm -f dist/pages/index.html && rm -f workflows.zip && zip -r workflows.zip src/ dist package.json tsconfig.json"
  },
  "dependencies": {
    "@greaseclaw/workflow-sdk": "github:greasedev/workflow-sdk#b0a788000a8d32abedee7d25a304aaa82d38ccb3"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "tsx": "^4.21.0",
    "vite": "^8.0.10",
    "vite-plugin-singlefile": "^2.3.3"
  },
  "packageManager": "pnpm@10.30.3+sha512.c961d1e0a2d8e354ecaa5166b822516668b7f44cb5bd95122d590dd81922f606f5473b6d23ec4a5be05e7fcd18e8488d47d978bbe981872f1145d06e9a740017"
}
